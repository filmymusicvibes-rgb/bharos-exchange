rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════
    // 🔒 USERS — Read: open (needed for admin, commission, leaderboard)
    //            Write: authenticated only
    //            Block: role changes by non-admins
    // ═══════════════════════════════════════════
    match /users/{userId} {
      allow read: if true;
      
      allow write: if request.auth != null
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
          || resource.data.role == 'admin'
        );
      
      allow create: if request.auth != null;
    }

    // ═══════════════════════════════════════════
    // 💰 TRANSACTIONS — Read: open, Create: authenticated
    // ═══════════════════════════════════════════
    match /transactions/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════
    // 💸 WITHDRAWALS — Read: open, Create/Update: authenticated
    // ═══════════════════════════════════════════
    match /withdrawals/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // 💳 DEPOSITS — Read: open, Create/Update: authenticated
    // ═══════════════════════════════════════════
    match /deposits/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // 🔗 REFERRAL INDEX — Read: open, Create: authenticated
    // ═══════════════════════════════════════════
    match /referralIndex/{code} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════
    // ⚙️ CONFIG — Read: open, Write: authenticated
    // ═══════════════════════════════════════════
    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // 🔐 ADMINS — Read: open (admin login check)
    //             Write: BLOCKED
    // ═══════════════════════════════════════════
    match /admins/{id} {
      allow read: if true;
      allow write: if false;
    }

    // ═══════════════════════════════════════════
    // 🏆 TRIP SUBMISSIONS — Read: open, Create: authenticated
    // ═══════════════════════════════════════════
    match /tripSubmissions/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════
    // 🪙 BRS WITHDRAWALS — Read: open, Create/Update: authenticated
    // ═══════════════════════════════════════════
    match /brs_withdrawals/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ═══════════════════════════════════════════
    // 📢 ANNOUNCEMENTS — Read: open, Write/Delete: authenticated
    // ═══════════════════════════════════════════
    match /announcements/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

  }
}