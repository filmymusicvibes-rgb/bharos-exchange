        "USDT",
        "BRS"
      ],
      "description": "Currency type"
    },
    "creator": {
      "bsonType": "string",
      "description": "User ID of creator"
    },
    "creatorEmail": {
      "bsonType": "string",
      "description": "Creator user email"
    },
    "createdAt": {
      "bsonType": "string",
      "title": "datetime",
      "description": "ISO 8601 datetime string (UTC): YYYY-MM-DDTHH:mm:ss.sssZ"
    },
    "updatedAt": {
      "bsonType": "string",
      "title": "datetime",
      "description": "ISO 8601 datetime string (UTC): YYYY-MM-DDTHH:mm:ss.sssZ"
    }
